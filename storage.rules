rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Restaurant images (icon + cover)
    // Any authenticated user with 'restaurant' role can upload to their path
    match /restaurants/{restaurantId}/{fileName} {
      // Public read — anyone can view restaurant images
      allow read: if true;

      // Authenticated users can upload (max 5MB, images only)
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Menu item images
    match /menu_items/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Offer images
    match /offers/{offerId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
